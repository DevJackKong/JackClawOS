# JackClaw Environment Variables
# Copy to .env or set in your shell

# ─── Hub Configuration ────────────────────────────────────────────
HUB_PORT=3100
JACKCLAW_HUB_URL=http://localhost:3100

# ─── Node Configuration ───────────────────────────────────────────
NODE_PORT=19000
JACKCLAW_NODE_ID=my-node

# ─── 国际大模型 (International LLMs) ──────────────────────────────

# Anthropic — Claude (claude-sonnet-4-6, claude-opus-4, claude-haiku-3-5)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # 可替换为中转站

# OpenAI — GPT (gpt-4o, gpt-4o-mini, o1, o3-mini)
OPENAI_API_KEY=sk-...

# Google — Gemini (gemini-2.0-flash, gemini-1.5-pro)
GOOGLE_API_KEY=AIza...

# DeepSeek — deepseek-chat, deepseek-reasoner（价格极低）
DEEPSEEK_API_KEY=sk-...

# Groq — 极速推理 (llama-3.3-70b, mixtral)
GROQ_API_KEY=gsk_...

# Mistral
MISTRAL_API_KEY=...

# Together AI — 200+ 开源模型
TOGETHER_API_KEY=...

# OpenRouter — 任意模型统一接入
OPENROUTER_API_KEY=sk-or-...

# Ollama — 本地模型（无需 key，运行 ollama serve 即可）
# OLLAMA_BASE_URL=http://localhost:11434

# ─── 国内大模型 (Chinese LLMs) ────────────────────────────────────

# 通义千问 — 阿里云 (qwen-max, qwen-plus, qwen-turbo)
# 控制台: https://dashscope.console.aliyun.com/
QWEN_API_KEY=sk-...

# 文心一言 — 百度千帆 (ernie-4.5-turbo, ernie-4.0, ernie-speed)
# 控制台: https://console.bce.baidu.com/qianfan/
ERNIE_API_KEY=...

# 混元 — 腾讯云 (hunyuan-pro, hunyuan-turbo, hunyuan-standard)
# 控制台: https://console.cloud.tencent.com/hunyuan
HUNYUAN_API_KEY=...

# 讯飞星火 — iFlytek (generalv3.5, generalv3, lite)
# 控制台: https://xinghuo.xfyun.cn/sparkapi
SPARK_API_KEY=...

# Kimi — Moonshot AI (moonshot-v1-8k/32k/128k)
# 控制台: https://platform.moonshot.cn/
KIMI_API_KEY=sk-...

# 智谱 GLM — 清华 (glm-4, glm-4-flash 免费!, glm-4-air)
# 控制台: https://open.bigmodel.cn/
ZHIPU_API_KEY=...

# 百川 AI (Baichuan4, Baichuan3-Turbo)
# 控制台: https://platform.baichuan-ai.com/
BAICHUAN_API_KEY=...
