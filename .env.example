# JackClaw Environment Variables

# Hub Configuration
HUB_PORT=3100                     # Hub HTTP port
JWT_SECRET=                       # Leave empty to auto-generate

# Node Configuration
NODE_PORT=19000                   # Node HTTP port
JACKCLAW_HUB_URL=http://localhost:3100  # Hub URL for node registration
JACKCLAW_NODE_ID=                 # Override auto-derived node ID

# AI Configuration (for agent nodes)
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=                # Your Anthropic API key
# ANTHROPIC_AUTH_TOKEN=           # Alternative auth token

# OpenClaw Integration
# OPENCLAW_WORKSPACE=~/.openclaw/workspace

# Memory Sync (cross-node)
# JACKCLAW_SYNC_SECRET=           # Required for memory sync between nodes
