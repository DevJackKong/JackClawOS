# JackClaw Hub — Production Environment Variables
# Copy to .env and fill in real values before deploying.
# NEVER commit .env to version control.

# ─── Required ─────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-strong-secret

# Public URL of this Hub (used in invite links, federation, etc.)
HUB_URL=https://your-domain.example.com

# ─── Node Environment ─────────────────────────────────────────────
NODE_ENV=production

# ─── Hub Port (internal, Nginx proxies externally) ────────────────
HUB_PORT=3100

# ─── Data Persistence ─────────────────────────────────────────────
# Host directory mounted as /data inside the container.
# The directory will be created automatically if it doesn't exist.
HUB_DATA_DIR=~/.jackclaw/hub

# ─── Logging ──────────────────────────────────────────────────────
# Levels: error | warn | info | debug
LOG_LEVEL=info

# ─── Image versioning (optional) ──────────────────────────────────
# Tag used when building/pulling the hub image.
VERSION=latest

# ─── SSL / Let's Encrypt (set in docker/nginx/hub.conf too) ───────
# Domain that Certbot will obtain a certificate for.
# Must match server_name in docker/nginx/hub.conf.
SSL_DOMAIN=your-domain.example.com
