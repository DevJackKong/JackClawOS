# ============================================================
# JackClaw 环境变量配置示例
# 复制此文件为 .env 并填写真实值
# Copy this file to .env and fill in real values
# ============================================================

# ------------------------------------------------------------
# Hub 配置 / Hub Configuration
# ------------------------------------------------------------

# Hub 服务监听端口
HUB_PORT=19001

# JWT 签名密钥（生产环境请使用强随机字符串）
# JWT signing secret (use a strong random string in production)
HUB_JWT_SECRET=your-secret-here

# Hub 数据持久化目录
HUB_DATA_DIR=~/.jackclaw/hub

# Hub 访问域名（对外暴露时填写）
# Public URL for Hub when exposed externally
HUB_PUBLIC_URL=https://your-hub-url

# ------------------------------------------------------------
# Node 配置 / Node Configuration
# ------------------------------------------------------------

# Node 服务监听端口
NODE_PORT=19000

# Node 唯一标识（留空则自动生成）
# Unique node ID (auto-generated if left empty)
NODE_ID=

# Node 显示名称（如：alice-macbook、bob-office）
NODE_NAME=

# Node 角色（owner / member / guest）
NODE_ROLE=

# Hub 连接地址
HUB_URL=https://your-hub-url

# ------------------------------------------------------------
# 汇报配置 / Report Configuration
# ------------------------------------------------------------

# 汇报 Cron 表达式（默认每天早 8 点）
# Report cron schedule (default: 8am daily)
REPORT_SCHEDULE=0 8 * * *

# 汇报可见性（summary_only / full / private）
# Report visibility: summary_only | full | private
REPORT_VISIBILITY=summary_only

# ------------------------------------------------------------
# 开发 / Development
# ------------------------------------------------------------

# 日志级别（debug / info / warn / error）
LOG_LEVEL=info

# 是否启用开发模式（跳过部分安全检查）
DEV_MODE=false
